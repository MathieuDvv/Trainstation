{
  "name": "ink-app",
  "version": "0.1.0",
  "description": "Terminal UI application built with Ink and React",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.tsx",
    "start": "tsx src/index.tsx",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ink": "^5.0.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/react": "^18.3.5",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
